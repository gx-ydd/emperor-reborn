# alibaba / openai-compatible / local
EMPEROR_PROVIDER=local

# 本地模型名称，必须和你的本地服务暴露的模型名一致
EMPEROR_MODEL=qwen2.5-coder:7b

# 本地 OpenAI-compatible endpoint
# Ollama 常见：     http://127.0.0.1:11434/v1
# LM Studio 常见：  http://127.0.0.1:1234/v1
# vLLM 常见：       http://127.0.0.1:8000/v1
EMPEROR_LOCAL_BASE_URL=http://127.0.0.1:11434/v1

# 可不填；默认会使用 local-no-key 占位
EMPEROR_LOCAL_API_KEY=

# 云端 DashScope 模式才需要
DASHSCOPE_API_KEY=
EMPEROR_ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI-compatible 云端模式才需要
OPENAI_BASE_URL=
OPENAI_API_KEY=

EMPEROR_HOST=127.0.0.1
EMPEROR_PORT=8765
EMPEROR_WORKSPACE=.
EMPEROR_MEMORY_DIR=memory
EMPEROR_PERMISSION_MODE=ask_before_edit